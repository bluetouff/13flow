# Copy to /etc/13flow/13flow-pro-backup.env, owner root:root, mode 0600.
PRO_DB=/var/lib/13flow-pro/13flow-pro.db
BACKUP_DIR=/var/backups/13flow-pro
BACKUP_RETENTION_DAYS=30

# Preferred: import a public backup key into this dedicated GPG home.
GPG_RECIPIENT=backup-key-fingerprint-or-email
GPG_HOMEDIR=/var/lib/13flow-pro-backup/gnupg

# Fallback only if public-key encryption is not available.
# BACKUP_PASSPHRASE_FILE=/etc/13flow/pro-backup.pass
