# Environment for the dedicated 13flow-pro.service.
# Keep SEC_UA, OPENFIGI_APIKEY and other ingest-only secrets out of this file.
SMARTMONEY_OPEN=1
SMARTMONEY_DB_READONLY=1
SMARTMONEY_DB=/var/lib/13flow/13flow.db
SMARTMONEY_CACHE_DIR=/var/lib/13flow
SMARTMONEY_CONFLUENCE_MIN_FUNDS=5
SMARTMONEY_PRO_API=1
SMARTMONEY_PRO_DB=/var/lib/13flow-pro/13flow-pro.db
# Production-only API-key binding. Generate a long random value on the server
# and never commit it:
#   openssl rand -hex 32
# SMARTMONEY_PRO_KEY_PEPPER=<server-only-secret>
# SMARTMONEY_PRO_REQUIRE_KEY_PEPPER=1
# Leave unset in production after rotation. Set to 1 only as a temporary
# migration window if legacy SHA-256 keys must remain accepted briefly.
# SMARTMONEY_PRO_ACCEPT_LEGACY_SHA256_KEYS=0
