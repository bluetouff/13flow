# Environment for the 13FLOW open (public, read-only) build.
# Copy to /etc/13flow/13flow.env and lock it down: chmod 640, owned by root:flowapp.

# --- The open build: no auth, no Stripe, no alerts. Public read-only screens only. ---
SMARTMONEY_OPEN=1

# Open the SQLite database read-only: the web process physically cannot write it.
# (Ingestion runs separately as another user; see refresh-data.sh.)
SMARTMONEY_DB_READONLY=1

# Absolute path to the database the web app reads.
SMARTMONEY_DB=/var/lib/13flow/13flow.db

# Where the resolver / OpenFIGI caches are written during ingestion (must be writable by the
# ingest user). Keep it next to the DB; the install dir (/opt/13flow) is intentionally read-only.
SMARTMONEY_CACHE_DIR=/var/lib/13flow

# Optional: live valuation via stooq (adds a price fetch per fund detail request). Off by default.
# SMARTMONEY_VALUE=1

# --- Confluence (13F × Form 4) ---
# Off => the Confluence tab serves sample data (no network).
# To compute it live you need EDGAR access AND a contact UA. Note: the live provider
# reads Form 4s on demand, which means outbound network from the web process; if you want
# the web tier to stay strictly read-only/offline, leave this off and precompute instead.
# SEC_UA=13FLOW/1.0 you@example.com
# SMARTMONEY_CONFLUENCE_LIVE=1
